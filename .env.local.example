# Copy to .env.local and set real values from Supabase → Project Settings → API
# URL must start with https:// (e.g. https://xxxx.supabase.co) — no spaces around =
# If you use quotes, use a single pair: NEXT_PUBLIC_SUPABASE_URL="https://....supabase.co"
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Yandex Maps JS API key — get one at https://developer.tech.yandex.ru/
# Select "JavaScript API and HTTP Geocoder", add localhost as allowed domain
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
